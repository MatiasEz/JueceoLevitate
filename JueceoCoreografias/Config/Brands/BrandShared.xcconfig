// Settings shared by every branded app target.

GENERATE_INFOPLIST_FILE = NO
INFOPLIST_FILE = JueceoCoreografias/Info.plist
INFOPLIST_FILE[sdk=macosx*] = JueceoCoreografias/Info-macOS.plist

DERIVE_MACCATALYST_PRODUCT_BUNDLE_IDENTIFIER = NO
CODE_SIGN_ENTITLEMENTS[sdk=macosx*] = JueceoCoreografias/Levitate-macOS.entitlements
